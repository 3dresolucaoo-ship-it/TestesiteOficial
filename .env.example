# Hayzer — Environment Variables
# (projeto rebatizado de "BVaz Hub" → "Hayzer" em 14/05/2026, ver decisions/009)
# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA é commitado (já está no .gitignore).

# ─── Supabase ────────────────────────────────────────────────────────────
# Public — usado no client e middleware
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — bypass RLS em rotas API e webhooks
# NUNCA expor no client. Adicionar em Vercel Dashboard como secret.
# OBRIGATÓRIO em prod — usado por:
#   - services/waitlist.ts (addLeadStep1, updateLeadStep2) — bypass RLS pra .insert().select()
#   - services/waitlistRateLimit.ts (countRecentLeadsByIpHash) — count cross-IP
#   - lib/supabaseAdmin.ts (getSupabaseAdmin)
# Pegar em: Supabase Dashboard → Settings → API Keys → "Legacy anon, service_role"
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────
# URL pública da aplicação. Em produção: https://hayzer.com.br
# (Vercel default https://bvaz-hub.vercel.app continua ativo como fallback até Onda 5)
# Usado para webhook URLs, OAuth redirects, metadataBase do Next.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Mercado Pago OAuth (app Marketplace) ────────────────────────────────
# Criar app em: https://www.mercadopago.com.br/developers/panel/app
# Tipo: Marketplace (não CheckoutPro)
# Adicionar redirect URI: ${NEXT_PUBLIC_APP_URL}/api/integrations/mercadopago/callback
MP_CLIENT_ID=your-mp-client-id
MP_CLIENT_SECRET=your-mp-client-secret

# ─── Mercado Pago Fallback (sem OAuth) ───────────────────────────────────
# Usado apenas se merchant não tiver config no DB
# (resolveProvider em services/payments.ts)
PAYMENT_PROVIDER=mercadopago
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=
MP_SANDBOX=false

# ─── Stripe Connect OAuth (botão "Conectar com Stripe") ─────────────────
# Criar plataforma em: https://dashboard.stripe.com/settings/connect
# Pegar o "Client ID" (formato ca_...)
# Adicionar redirect URI: ${NEXT_PUBLIC_APP_URL}/api/integrations/stripe/callback
STRIPE_CONNECT_CLIENT_ID=ca_...

# ─── Stripe — secret key da plataforma (usada no exchange OAuth) ─────────
# Também usada como fallback de provider quando merchant não tem config DB
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Bling (NFS-e) — quando integrar ─────────────────────────────────────
# BLING_CLIENT_ID=
# BLING_CLIENT_SECRET=

# ─── Instagram / Meta — quando integrar ──────────────────────────────────
# IG_ACCESS_TOKEN=
# IG_BUSINESS_ACCOUNT_ID=

# ─── YouTube Data API — quando integrar ──────────────────────────────────
# YT_API_KEY=

# ─── Resend (email transacional) — Fase 1 (em setup 14/05/2026) ──────────
# SDK instalado, services/email.ts implementado, wire-up em actions.ts pronto.
# Falta:
#  1. Criar conta em https://resend.com (CEO)
#  2. Adicionar domínio hayzer.com.br no Resend Dashboard → Domains
#  3. Configurar SPF + DKIM + DMARC no Registro.br (Resend gera os valores)
#  4. Aguardar verificação (5-30min)
#  5. Gerar API key + adicionar abaixo (e no Vercel env vars)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ola@hayzer.com.br

# Link convite grupo WhatsApp "Hayzer Beta" — aparece no email de boas-vindas.
# CEO cria o grupo manualmente no WhatsApp, copia o link `chat.whatsapp.com/...`,
# adiciona aqui e no Vercel env vars. Se vazio, email sai sem o botão (graceful).
NEXT_PUBLIC_WHATSAPP_GROUP_URL=

# ─── Sentry (error tracking em prod) — aplicar em 17/06/2026 (ADR-017) ────
# Cadastrar em: https://sentry.io (plano Developer, gratuito)
# Criar projeto: New Project -> Next.js -> nome: hayzer-prod
# DSN: Settings -> Projects -> hayzer-prod -> Client Keys
# Auth Token: Settings -> Auth Tokens -> Create Token (escopos: project:write, org:read)
# Ver instrucoes completas em _sentry-prepared/APPLY.md
NEXT_PUBLIC_SENTRY_DSN=https://[key]@o[org-id].ingest.us.sentry.io/[project-id]
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=hayzer
SENTRY_PROJECT=hayzer-prod

# ─── PostHog (analytics + funil) — Fase 2 estabilização ───────────────────
# Cadastrar em: https://posthog.com (plano free generoso pra MVP)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Discord Webhooks (Operacao Noturna G7) — ativo desde 2026-05-20 ──────
# Servidor "Hayzer Ops" criado pelo CEO em 2026-05-20.
# Usado por Claude durante operacao noturna (22h-7h BRT) para alertar CEO.
# #critico = mensagem com som que ACORDA o CEO (build prod quebrado, agent travado, pagamento erro).
# #digest = resumo informativo silencioso (le de manha: commits, docs, agents que terminaram).
# IMPORTANTE: nunca commitar URLs reais. Manter so em .env.local + Vercel env vars.
DISCORD_WEBHOOK_CRITICO=https://discord.com/api/webhooks/[id]/[token]
DISCORD_WEBHOOK_DIGEST=https://discord.com/api/webhooks/[id]/[token]

# ─── Upstash Redis (rate limit) — Fase 1 semana 2 ─────────────────────────
# https://upstash.com — free tier OK pra começar
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Vercel Bot Protection (Firewall) — ATIVO em modo Log desde 14/05/2026 ─
# https://vercel.com/docs/security/firewall/bot-protection
# Modo Log = registra bots desafiados sem bloquear (segurança pré-launch).
# Promover pra "On" após 1-2 semanas de observação no Audit Log do Firewall.
# (Verificado: nenhum webhook legítimo Stripe/MP rodando em prod ainda — risco zero hoje)

# ─── Admin Emails (whitelist de acesso a rotas administrativas) ──────────
# CSV de emails que têm acesso a:
#   - /mockups (sistema de mockups visuais)
#   - rotas futuras protegidas (/admin, /admin/leads, etc)
# Comparação case-insensitive. Em prod: setar no Vercel Dashboard.
# Em dev: 1 email do CEO basta. Múltiplos admins futuros separados por vírgula.
ADMIN_EMAILS=3dresolucaoo@gmail.com

# ─── Waitlist — salt do hash de IP (rate-limit) ──────────────────────────
# Usado pra hash SHA-256 do IP antes de salvar no DB (LGPD-friendly).
# Em prod (Vercel): valor random de 32 bytes hex já setado em 14/05/2026
# (não usar o fallback abaixo em produção — gerar novo com `openssl rand -hex 32`).
WAITLIST_IP_SALT=troca-isso-em-prod-32-chars-aleatorios

# ─── API Rate Limit — salt do hash de IP (Otávio 17/05) ──────────────────
# Mesmo padrão do WAITLIST_IP_SALT, mas pras rotas /api/checkout, /api/encomenda,
# /api/catalog/quote. Se vazio, services/apiRateLimit.ts cai pro WAITLIST_IP_SALT
# (compat sem precisar setar 2 valores). Em prod, recomendado ter SALT separado
# pra cada propósito (defense in depth — vazamento de um não compromete o outro).
# Gerar: `openssl rand -hex 32`
API_RATE_LIMIT_SALT=
